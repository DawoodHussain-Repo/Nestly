# MongoDB
MONGODB_URI=mongodb://localhost:27017/nestly

# JWT Secrets (Change these in production!)
ACCESS_TOKEN_SECRET=your-super-secret-access-token-key-change-this
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-change-this

# Seed Secret Key (for database seeding in development)
SEED_SECRET_KEY=your-seed-secret-key-change-this

# Node Environment
NODE_ENV=development
